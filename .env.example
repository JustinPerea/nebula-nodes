# Copy to .env and fill in your keys
# Only fill in the providers you use — leave the rest blank

# OpenAI (GPT Image 1, GPT-4o, DALL-E, Sora 2)
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# Google (Gemini, Imagen 4, Nano Banana)
GOOGLE_API_KEY=

# FAL (covers Kling, FLUX, Veo 3, Wan, LTX, Pixverse, Seedance, Luma, Sora, etc.)
FAL_KEY=

# Runway
RUNWAY_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Replicate
REPLICATE_API_TOKEN=

# OpenRouter
OPENROUTER_API_KEY=

# Black Forest Labs (FLUX direct)
BFL_API_KEY=

# ByteDance (Seedream)
BYTEDANCE_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# xAI (Grok)
XAI_API_KEY=

# Recraft
RECRAFT_API_KEY=

# Ideogram
IDEOGRAM_API_KEY=

# Higgsfield
HIGGSFIELD_API_KEY=
